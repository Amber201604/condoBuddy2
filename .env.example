# CondoBuddy2 — Environment Variables
# Copy to .env and fill in production values before deploying.

# REQUIRED — JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=

# Shared key for internal service-to-service calls (webhooks, device endpoints).
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# PostgreSQL
POSTGRES_USER=condobuddy
POSTGRES_PASSWORD=condobuddy
POSTGRES_DB=condobuddy2

# MinIO (object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MariaDB (Frappe)
MARIADB_ROOT_PASSWORD=condobuddy_mariadb_root

# Frappe bridge
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Token expiry (minutes). Default 1440 (1 day).
ACCESS_TOKEN_EXPIRE_MINUTES=1440
